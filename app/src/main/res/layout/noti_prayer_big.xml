<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/noti_big_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_noti_prayer_big"
    android:clipToOutline="true"
    android:outlineProvider="background">

    <ImageView
        android:id="@+id/noti_big_bg"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:scaleType="centerCrop"
        android:src="@mipmap/img_large_noti_bg" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/noti_big_verse"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:maxLines="4"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="If anyone is in Christ, he is a new creation;the old has gone, the new has come!"/>

        <TextView
            android:id="@+id/noti_big_chapter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/noti_big_verse"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:maxLines="1"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="2 Corinthians 5:17"/>

        <TextView
            android:id="@+id/noti_big_action"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_below="@id/noti_big_chapter"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_noti_prayer_button"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Morning Prayer"/>
    </LinearLayout>
</FrameLayout>
