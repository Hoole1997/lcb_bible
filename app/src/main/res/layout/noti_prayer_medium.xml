<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/noti_medium_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_noti_prayer_card"
    android:padding="14dp">

    <LinearLayout
        android:id="@+id/noti_medium_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/noti_medium_thumb"
            android:layout_width="50dp"
            android:layout_height="28dp"
            android:scaleType="fitStart"
            android:src="@mipmap/img_noti_bg_small" />

        <TextView
            android:id="@+id/noti_medium_verse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="#333333"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/noti_medium_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/noti_medium_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_noti_prayer_button"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:paddingVertical="2dp"
        android:textStyle="bold" />

</RelativeLayout>
