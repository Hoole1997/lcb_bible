<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DF9C67">

        <ImageView
            android:id="@+id/hero_bg"
            android:layout_width="match_parent"
            android:layout_height="236dp"
            android:importantForAccessibility="no"
            android:scaleType="centerCrop"
            android:src="@mipmap/img_qa_header_bg"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/white_sheet"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="-72dp"
            android:background="@drawable/bg_answer_white_sheet"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/hero_bg" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingTop="52dp"
            android:paddingBottom="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/layout_coin"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_study_coin"
                android:gravity="center_vertical"
                android:minWidth="95dp"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/countdown_ring_container"
                app:layout_constraintBottom_toBottomOf="@id/countdown_ring_container">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:importantForAccessibility="no"
                    android:src="@mipmap/img_kjv_coin" />

                <TextView
                    android:id="@+id/text_coin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#ffffff"
                    android:textSize="14sp"
                    tools:text="326" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_level"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_study_coin"
                android:gravity="center"
                android:minWidth="95dp"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/countdown_ring_container"
                app:layout_constraintBottom_toBottomOf="@id/countdown_ring_container">

                <TextView
                    android:id="@+id/text_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    tools:text="Level 2" />

            </LinearLayout>

            <FrameLayout
                android:id="@+id/countdown_ring_container"
                android:layout_width="82dp"
                android:layout_height="82dp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/countdown_progress"
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:layout_gravity="center"
                    android:indeterminate="false"
                    android:max="10000"
                    app:indicatorColor="@android:color/white"
                    app:indicatorDirectionCircular="clockwise"
                    app:indicatorSize="82dp"
                    app:trackColor="#66FFFFFF"
                    app:trackCornerRadius="2dp"
                    app:trackThickness="4dp"
                    tools:progress="6000" />

                <View
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_countdown_inner_circle" />

                <TextView
                    android:id="@+id/text_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="@android:color/white"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    tools:text="30" />

            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/card_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@id/bottom_actions"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header_bar">

            <TextView
                android:id="@+id/text_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:textColor="#792D0B"
                android:textSize="18sp"
                tools:text="1/3 Question" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="#E8D9C8" />

            <TextView
                android:id="@+id/text_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="4dp"
                android:textColor="#5A251B"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="On the ________ day, God created man in his own image." />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/option_a"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_answer_option_pill">

                <TextView
                    android:id="@+id/option_a_text"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toStartOf="@+id/option_a_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:text="A. First" />

                <ImageView
                    android:id="@+id/option_a_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:importantForAccessibility="no"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/option_b"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_answer_option_pill">

                <TextView
                    android:id="@+id/option_b_text"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toStartOf="@+id/option_b_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:text="B. Third" />

                <ImageView
                    android:id="@+id/option_b_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:importantForAccessibility="no"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/option_c"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_answer_option_pill">

                <TextView
                    android:id="@+id/option_c_text"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toStartOf="@+id/option_c_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:text="C. Sixth" />

                <ImageView
                    android:id="@+id/option_c_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:importantForAccessibility="no"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/option_d"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_answer_option_pill">

                <TextView
                    android:id="@+id/option_d_text"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toStartOf="@+id/option_d_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:text="D. Seventh" />

                <ImageView
                    android:id="@+id/option_d_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:importantForAccessibility="no"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

        <com.mobile.bible.kjv.ui.view.PaddingBlurOverlayView
            android:id="@+id/card_blur_overlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/card_container"
            app:layout_constraintEnd_toEndOf="@id/card_container"
            app:layout_constraintStart_toStartOf="@id/card_container"
            app:layout_constraintTop_toTopOf="@id/card_container" />

        <LinearLayout
            android:id="@+id/bottom_actions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="46dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <FrameLayout
                android:id="@+id/action_pause"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/svg_study_pause" />

            <FrameLayout
                android:id="@+id/action_add_time"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="20dp"
                android:background="@drawable/svg_use_delay">

                <TextView
                    android:id="@+id/props_a_count"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="end|top"
                    android:background="@drawable/bg_action_count"
                    android:gravity="center"
                    android:textColor="#884638"
                    android:textSize="10sp"
                    tools:ignore="SmallSp"
                    tools:text="2" />

                <LinearLayout
                    android:id="@+id/buy_delay"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal|bottom"
                    android:background="@drawable/bg_action_hint"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_gravity="center_vertical"
                        android:src="@mipmap/img_kjv_coin" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:gravity="center"
                        android:text="25"
                        android:textColor="#884638"
                        android:textSize="11sp"
                        tools:ignore="SmallSp" />

                </LinearLayout>

            </FrameLayout>

            <FrameLayout
                android:id="@+id/action_reselect"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="20dp"
                android:background="@drawable/svg_use_eraser">

                <TextView
                    android:id="@+id/props_b_count"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="end|top"
                    android:background="@drawable/bg_action_count"
                    android:gravity="center"
                    android:textColor="#884638"
                    android:textSize="10sp"
                    tools:ignore="SmallSp"
                    tools:text="2" />

                <LinearLayout
                    android:id="@+id/buy_eraser"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal|bottom"
                    android:background="@drawable/bg_action_hint"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_gravity="center_vertical"
                        android:src="@mipmap/img_kjv_coin" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:gravity="center"
                        android:text="25"
                        android:textColor="#884638"
                        android:textSize="11sp"
                        tools:ignore="SmallSp" />

                </LinearLayout>

            </FrameLayout>

            <FrameLayout
                android:id="@+id/view_ad"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="20dp"
                android:background="@drawable/svg_make_coin">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal|bottom"
                    android:background="@drawable/bg_action_hint"
                    android:gravity="center"
                    android:minWidth="48dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="4dp">

                    <ImageView
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_gravity="center_vertical"
                        android:src="@mipmap/img_kjv_coin" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:gravity="center"
                        android:text="@string/add50"
                        android:textColor="#884638"
                        android:textSize="11sp"
                        tools:ignore="SmallSp" />

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
