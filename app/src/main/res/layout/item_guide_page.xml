<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ImageView
        android:id="@+id/bgImageEx"
        android:layout_width="308dp"
        android:layout_height="170dp"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/bgImage"
        android:src="@drawable/svg_splash_guide_bg" />

    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="308dp"
        android:layout_height="266dp"
        android:importantForAccessibility="no"
        android:scaleType="centerInside"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:src="@mipmap/img_splash_guide_a"
        android:layout_marginTop="132dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="300dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@mipmap/img_splash_guide_bg"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/guide_a_msg_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="gone"
        tools:visibility="gone">

        <TextView
            android:id="@+id/guide_a_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666666"
            android:text="@string/skip"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/guide_a_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/guide_a_title"
            android:textColor="#000000"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textAlignment="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/guide_a_btn_next"
            android:layout_marginBottom="20dp"
            android:layout_marginHorizontal="36dp"/>

        <TextView
            android:id="@+id/guide_a_btn_next"
            android:layout_width="252dp"
            android:layout_height="60dp"
            android:background="@drawable/svg_guide_btn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/guide_a_hint"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:text="@string/guide_continue"/>

        <TextView
            android:id="@+id/guide_a_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/guide_hint"
            android:textColor="#A1A19C"
            android:textSize="12sp"
            android:textStyle="normal"
            android:gravity="center"
            android:minLines="2"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="62dp"
            android:layout_marginHorizontal="30dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/guide_b_msg_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="gone"
        tools:visibility="gone">

        <TextView
            android:id="@+id/guide_b_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666666"
            android:text="@string/skip"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/guide_b_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/guide_b_title"
            android:textColor="#000000"
            android:textAlignment="center"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/guide_b_btn_next"
            android:layout_marginHorizontal="36dp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/guide_b_btn_next"
            android:layout_width="252dp"
            android:layout_height="60dp"
            android:background="@drawable/svg_guide_btn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/guide_b_hint"
            android:layout_marginBottom="32dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:text="@string/guide_continue"/>

        <TextView
            android:id="@+id/guide_b_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/guide_hint"
            android:textColor="#A1A19C"
            android:textSize="12sp"
            android:textStyle="normal"
            android:gravity="center"
            android:minLines="2"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="62dp"
            android:layout_marginHorizontal="30dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/guide_c_msg_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="gone"
        tools:visibility="gone">

        <TextView
            android:id="@+id/guide_c_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666666"
            android:text="@string/skip"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/guide_c_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/guide_c_title"
            android:textColor="#000000"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textAlignment="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/guide_c_btn_next"
            android:layout_marginBottom="20dp"
            android:layout_marginHorizontal="36dp"/>

        <TextView
            android:id="@+id/guide_c_btn_next"
            android:layout_width="252dp"
            android:layout_height="60dp"
            android:background="@drawable/svg_guide_btn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/guide_c_hint"
            android:layout_marginBottom="32dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:text="@string/guide_continue"/>

        <TextView
            android:id="@+id/guide_c_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/guide_hint"
            android:textColor="#A1A19C"
            android:textSize="12sp"
            android:textStyle="normal"
            android:gravity="center"
            android:minLines="2"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="62dp"
            android:layout_marginHorizontal="30dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/guide_d_msg_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/guide_d_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666666"
            android:text="@string/skip"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            tools:visibility="visible"/>

        <TextView
            android:id="@+id/guide_d_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/guide_d_title"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/guide_d_subtitle"
            android:layout_marginBottom="12dp"
            android:layout_marginHorizontal="24dp"/>

        <TextView
            android:id="@+id/guide_d_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/guide_d_subtitle"
            android:gravity="center"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="normal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/guide_d_btn_next"
            android:layout_marginBottom="20dp"
            android:layout_marginHorizontal="36dp" />

        <TextView
            android:id="@+id/guide_d_btn_next"
            android:layout_width="252dp"
            android:layout_height="60dp"
            android:background="@drawable/svg_guide_btn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/guide_d_hint"
            android:layout_marginBottom="32dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:text="@string/guide_continue"/>

        <TextView
            android:id="@+id/guide_d_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/guide_hint"
            android:textColor="#A1A19C"
            android:textSize="12sp"
            android:textStyle="normal"
            android:gravity="center"
            android:minLines="2"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="62dp"
            android:layout_marginHorizontal="30dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
