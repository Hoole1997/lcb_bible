<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="30dp">

    <ImageView
        android:id="@+id/image_ribbon"
        android:layout_width="206dp"
        android:layout_height="83dp"
        android:importantForAccessibility="no"
        android:src="@mipmap/img_lottery_tag"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_answer_dialog"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/image_ribbon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-28dp">

        <ImageView
            android:id="@+id/button_cancel"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:importantForAccessibility="no"
            android:src="@drawable/svg_cancel"
            app:tint="#BBB7AD"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/text_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="@string/lottery_title"
            android:textColor="#673C0F"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/image_coins"
            android:layout_width="132dp"
            android:layout_height="81dp"
            android:layout_marginTop="16dp"
            android:importantForAccessibility="no"
            android:src="@mipmap/img_lottery_coins"
            android:scaleType="fitCenter"
            app:layout_constraintTop_toBottomOf="@id/text_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/layout_eraser_delay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/text_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/image_eraser"
                android:layout_width="66dp"
                android:layout_height="66dp"
                android:importantForAccessibility="no"
                android:src="@mipmap/img_lottery_eraser"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/image_add"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="8dp"
                android:importantForAccessibility="no"
                android:src="@drawable/svg_lottery_add"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/image_delay"
                android:layout_width="66dp"
                android:layout_height="66dp"
                android:importantForAccessibility="no"
                android:src="@mipmap/img_lottery_delay"
                android:scaleType="fitCenter" />

        </LinearLayout>

        <TextView
            android:id="@+id/text_message_coin_double"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="20dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:textColor="#A4855D"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/text_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Congratulations! Your rewards\nhave been doubled!" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_coin_double"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/text_message_coin_double"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/container_coin_small"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:background="@drawable/bg_coin_double_item"
                app:layout_constraintBottom_toBottomOf="@id/container_coin_large"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/image_arrow_double">

                <ImageView
                    android:id="@+id/image_coin_small"
                    android:layout_width="58dp"
                    android:layout_height="33dp"
                    android:layout_marginTop="12dp"
                    android:importantForAccessibility="no"
                    android:src="@mipmap/img_lottery_coins"
                    android:scaleType="fitCenter"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/text_coin_small_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="#A4855D"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/image_coin_small"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:text="100" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <ImageView
                android:id="@+id/image_arrow_double"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="4dp"
                android:importantForAccessibility="no"
                android:src="@mipmap/img_lottery_increase"
                android:scaleType="fitCenter"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/container_coin_small"
                app:layout_constraintEnd_toStartOf="@id/container_coin_large" />

            <TextView
                android:id="@+id/text_x2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="x2"
                android:textColor="#F4241E"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/image_arrow_double"
                app:layout_constraintStart_toStartOf="@id/image_arrow_double"
                app:layout_constraintEnd_toEndOf="@id/image_arrow_double" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/container_coin_large"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_coin_double_item"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/image_arrow_double"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/image_coin_large"
                    android:layout_width="80dp"
                    android:layout_height="46dp"
                    android:layout_marginTop="15dp"
                    android:importantForAccessibility="no"
                    android:src="@mipmap/img_lottery_coins"
                    android:scaleType="fitCenter"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/text_coin_large_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="#A4855D"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/image_coin_large"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:text="200" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_eraser_delay_double"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/text_message_coin_double"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/container_eraser_delay_small"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:background="@drawable/bg_coin_double_item"
                app:layout_constraintBottom_toBottomOf="@id/container_eraser_delay_large"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/image_arrow_eraser_delay_double">

                <ImageView
                    android:id="@+id/image_eraser_small_double"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginTop="16dp"
                    android:importantForAccessibility="no"
                    android:src="@mipmap/img_lottery_eraser"
                    android:scaleType="fitCenter"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/image_add_small_double"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:id="@+id/image_add_small_double"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/svg_lottery_add"
                    android:scaleType="fitCenter"
                    app:layout_constraintTop_toTopOf="@id/image_eraser_small_double"
                    app:layout_constraintBottom_toBottomOf="@id/image_eraser_small_double"
                    app:layout_constraintStart_toEndOf="@id/image_eraser_small_double"
                    app:layout_constraintEnd_toStartOf="@id/image_delay_small_double" />

                <ImageView
                    android:id="@+id/image_delay_small_double"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginTop="16dp"
                    android:importantForAccessibility="no"
                    android:src="@mipmap/img_lottery_delay"
                    android:scaleType="fitCenter"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/image_add_small_double"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/text_eraser_delay_small_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#A4855D"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/image_add_small_double"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:text="x2" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <ImageView
                android:id="@+id/image_arrow_eraser_delay_double"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="4dp"
                android:importantForAccessibility="no"
                android:src="@mipmap/img_lottery_increase"
                android:scaleType="fitCenter"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/container_eraser_delay_small"
                app:layout_constraintEnd_toStartOf="@id/container_eraser_delay_large" />

            <TextView
                android:id="@+id/text_x2_eraser_delay_double"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="x2"
                android:textColor="#F4241E"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"
                app:layout_constraintTop_toBottomOf="@id/image_arrow_eraser_delay_double"
                app:layout_constraintStart_toStartOf="@id/image_arrow_eraser_delay_double"
                app:layout_constraintEnd_toEndOf="@id/image_arrow_eraser_delay_double" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/container_eraser_delay_large"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_coin_double_item"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/image_arrow_eraser_delay_double"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/image_eraser_large_double"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginTop="20dp"
                    android:importantForAccessibility="no"
                    android:src="@mipmap/img_lottery_eraser"
                    android:scaleType="fitCenter"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/image_add_large_double"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:id="@+id/image_add_large_double"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/svg_lottery_add"
                    android:scaleType="fitCenter"
                    app:layout_constraintTop_toTopOf="@id/image_eraser_large_double"
                    app:layout_constraintBottom_toBottomOf="@id/image_eraser_large_double"
                    app:layout_constraintStart_toEndOf="@id/image_eraser_large_double"
                    app:layout_constraintEnd_toStartOf="@id/image_delay_large_double" />

                <ImageView
                    android:id="@+id/image_delay_large_double"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginTop="20dp"
                    android:importantForAccessibility="no"
                    android:src="@mipmap/img_lottery_delay"
                    android:scaleType="fitCenter"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/image_add_large_double"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/text_eraser_delay_large_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#A4855D"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/image_add_large_double"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="10dp"
                    tools:text="x4" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_icons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="image_coins,layout_eraser_delay,layout_coin_double,layout_eraser_delay_double" />

        <TextView
            android:id="@+id/text_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="20dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:textColor="#A4855D"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/barrier_icons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="You've earned 100 coins.\nWell done!" />

        <TextView
            android:id="@+id/button_confirm"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/bg_answer_try_again"
            android:gravity="center"
            android:text="@string/lottery_confirm"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/text_message"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/button_claim_2x"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/bg_answer_try_again_normal"
            app:layout_constraintTop_toBottomOf="@id/button_confirm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/text_claim_2x"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lottery_claim_2x"
                android:textColor="#673C0F"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:id="@+id/image_video"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:importantForAccessibility="no"
                android:src="@drawable/svg_rewarded_ad"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/text_claim_2x"
                app:tint="#DF9C67"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
