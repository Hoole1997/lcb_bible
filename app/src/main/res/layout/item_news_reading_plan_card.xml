<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="156dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_journey_button_start">

    <ImageView
        android:id="@+id/icon_plan"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:importantForAccessibility="no"
        tools:src="@drawable/svg_starting_today"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"/>

    <TextView
        android:id="@+id/plan_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#999999"
        tools:text="Faith Plan"
        android:layout_marginStart="6dp"
        app:layout_constraintTop_toTopOf="@id/icon_plan"
        app:layout_constraintBottom_toBottomOf="@id/icon_plan"
        app:layout_constraintStart_toEndOf="@id/icon_plan"/>

    <TextView
        android:id="@+id/plan_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#333333"
        android:layout_marginTop="10dp"
        tools:text="7 Days of Faith"
        app:layout_constraintStart_toStartOf="@id/icon_plan"
        app:layout_constraintTop_toBottomOf="@id/icon_plan"
        android:layout_marginHorizontal="12dp"
        android:maxLines="4"
        android:minLines="4"
        android:ellipsize="end"/>

    <TextView
        android:id="@+id/plan_desc"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:textSize="11sp"
        android:textColor="#999999"
        android:layout_marginTop="8dp"
        tools:text="Building a strong foundation."
        app:layout_constraintTop_toBottomOf="@id/plan_title"
        android:layout_marginHorizontal="12dp"
        android:maxLines="2"
        android:minLines="2"
        android:visibility="gone"
        android:ellipsize="end"/>

    <TextView
        android:id="@+id/badge"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        tools:background="@drawable/bg_plan_btn_red"
        app:layout_constraintTop_toBottomOf="@id/plan_desc"
        android:layout_marginTop="10dp"
        android:paddingVertical="8dp"
        tools:text="Starting today" />

</androidx.constraintlayout.widget.ConstraintLayout>
