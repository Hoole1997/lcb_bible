<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@mipmap/img_listen_bg">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/svg_back"
                app:tint="#FFFFFF"
                android:layout_marginStart="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:text="@string/your_journey"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/progress_today_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="36dp"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp">

            <TextView
                android:id="@+id/progress_today_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="@string/progress_today"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/progress_today_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F5B553"
                android:textSize="12sp"
                tools:text="30%"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/progress_today_title"
                app:layout_constraintBottom_toBottomOf="@id/progress_today_title" />

            <ProgressBar
                android:id="@+id/progress_today_bar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#F5B553"
                android:progressBackgroundTint="#4DFFFFFF"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/progress_today_title"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/progress_today_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                tools:text="YOUR VERSE ·1 MIN"
                app:layout_constraintTop_toBottomOf="@id/progress_today_bar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="40dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progress_today_card"
            app:layout_constraintBottom_toTopOf="@id/player_controls"
            android:layout_marginVertical="30dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/quote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    tools:text="Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you...Fear not, for I am with you..."
                    android:layout_marginStart="30dp"
                    android:layout_marginEnd="30dp"
                    android:lineSpacingExtra="12sp"/>

                <LinearLayout
                    android:id="@+id/position"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:layout_marginHorizontal="30dp"
                    tools:ignore="UseCompoundDrawables"
                    android:layout_gravity="center_vertical">

                    <ImageView
                        android:id="@+id/img_verse_position"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:importantForAccessibility="no"
                        android:src="@drawable/svg_book"/>

                    <TextView
                        android:id="@+id/verse_position"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Isaiah 41.10"
                        android:textAlignment="center"
                        android:textColor="#D7AF78"
                        android:textSize="14sp"
                        android:layout_marginStart="10dp"
                        android:layout_marginBottom="2dp"/>

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/player_controls"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp">

            <ProgressBar
                android:id="@+id/progress_bar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:max="100"
                tools:progress="30"
                android:progressTint="#FFFFFFFF"
                android:progressBackgroundTint="#66FFFFFF"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:visibility="invisible"/>

            <TextView
                android:id="@+id/time_current"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                tools:text="00:00"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/progress_bar" />

            <TextView
                android:id="@+id/time_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                tools:text="02:32"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/progress_bar"/>

            <ImageView
                android:id="@+id/verse_player_share"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/svg_verse_player_share"
                app:layout_constraintTop_toBottomOf="@id/progress_bar"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/progress_bar"
                android:layout_marginTop="50dp"
                android:layout_marginBottom="62dp"/>

            <ImageView
                android:id="@+id/verse_player_last"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/svg_last_enable"
                app:layout_constraintTop_toTopOf="@id/verse_player_share"
                app:layout_constraintBottom_toBottomOf="@id/verse_player_share"
                app:layout_constraintStart_toEndOf="@id/verse_player_share"
                app:layout_constraintEnd_toStartOf="@id/verse_player_play"/>

            <ImageView
                android:id="@+id/verse_player_play"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:importantForAccessibility="no"
                android:src="@drawable/svg_verse_player_play"
                app:layout_constraintTop_toTopOf="@id/verse_player_share"
                app:layout_constraintBottom_toBottomOf="@id/verse_player_share"
                app:layout_constraintStart_toEndOf="@id/verse_player_last"
                app:layout_constraintEnd_toStartOf="@id/verse_player_next"/>

            <ImageView
                android:id="@+id/verse_player_next"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/svg_next_enable"
                app:layout_constraintTop_toTopOf="@id/verse_player_share"
                app:layout_constraintBottom_toBottomOf="@id/verse_player_share"
                app:layout_constraintStart_toEndOf="@id/verse_player_play"
                app:layout_constraintEnd_toStartOf="@id/verse_player_mode"/>

            <ImageView
                android:id="@+id/verse_player_mode"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/svg_verse_player_mode"
                app:layout_constraintTop_toTopOf="@id/verse_player_share"
                app:layout_constraintBottom_toBottomOf="@id/verse_player_share"
                app:layout_constraintEnd_toEndOf="@id/progress_bar"/>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
