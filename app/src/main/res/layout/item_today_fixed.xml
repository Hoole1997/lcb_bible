<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="374dp"
    xmlns:tools="http://schemas.android.com/tools">

    <ImageView
        android:id="@+id/today_fix_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        android:scaleType="centerCrop"
        android:src="@mipmap/img_today_appbar"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/today_fixed_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@drawable/bg_bible_today_fixed_info">

        <TextView
            android:id="@+id/info_verse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            android:textColor="#633800"
            android:textSize="20sp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            android:textStyle="bold"
            tools:text="For it pleased the Father that inhim should all fulness dwell."/>

        <ImageView
            android:id="@+id/icon_verse_position"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:importantForAccessibility="no"
            android:src="@drawable/svg_colossians"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/info_verse"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/info_verse_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Colossians 1:19 (NIV)"
            android:layout_marginStart="6dp"
            android:textColor="#A4855D"
            android:textSize="12sp"
            app:layout_constraintTop_toTopOf="@id/icon_verse_position"
            app:layout_constraintBottom_toBottomOf="@id/icon_verse_position"
            app:layout_constraintStart_toEndOf="@id/icon_verse_position"/>

        <ImageView
            android:id="@+id/icon_verse_share"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:importantForAccessibility="no"
            android:src="@drawable/svg_share"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/icon_verse_position"
            app:layout_constraintBottom_toBottomOf="@id/icon_verse_position"
            android:layout_marginEnd="16dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
