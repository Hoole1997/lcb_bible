<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application
        android:name="com.mobile.bible.kjv.KjvApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KJVBible">
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="${ADMOB_APPLICATION_ID}" />

        <activity
            android:name="com.mobile.bible.kjv.ui.activity.KjvSplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.mobile.bible.kjv.ui.activity.KjvHomeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Theme.Bible.NoActionBar" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.OpenKjvVideoActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Theme.Bible.NoActionBar" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.DebugActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.GuideActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.GuideFloatingWindowActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar.Fullscreen" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.VersePlayerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.VerseReadActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.PrayerWallEditActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.PlayerCreateLoadingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.PlayerAddedHintActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.MyPostsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.AnswerQuestionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.AnswerFailedActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.LevelFailedActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder" />
        <activity
            android:name="com.mobile.bible.kjv.ui.activity.PrivacyPolicyActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="standard"
            android:theme="@style/Base.Theme.MaterialThemeBuilder" />

        <receiver
            android:name="com.mobile.bible.kjv.noti.LocalNotiAlarmReceiver"
            android:exported="false" />

        <receiver
            android:name="com.mobile.bible.kjv.noti.LocalNotiBootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
